---
import Layout from '../../../layouts/Layout.astro';
import StatsNav from '../../../components/StatsNav.astro';
import { loadBooks, countMap, shortTitle, safeJsonForScript} from '../../../lib/bookshelf-stats';

const books = await loadBooks();
const authorCounts = countMap(books.map((b) => b.author));
const multiAuthors = authorCounts.filter(([, n]) => n >= 2);

type Node = {
  id: string;
  label: string;
  n: number;
  x: number;
  y: number;
  r: number;
  books: { id: string; t: string; d: number; r: number | null; cover: string | null; color: string | null }[];
};

const W = 640;
const H = 520;
const CX = W / 2;
const CY = H / 2;

const nodes: Node[] = multiAuthors.map(([author, n], i) => {
  const angle = (i / multiAuthors.length) * Math.PI * 2 - Math.PI / 2;
  const ring = n >= 8 ? 0 : n >= 3 ? 1 : 2;
  const radius = ring === 0 ? 0 : ring === 1 ? 145 : 220;
  const jitter = ((i * 37) % 17) - 8;
  const x = ring === 0 && i === 0 ? CX : CX + Math.cos(angle) * (radius + jitter);
  const y = ring === 0 && i === 0 ? CY : CY + Math.sin(angle) * (radius + jitter * 0.6);
  const authorBooks = books
    .filter((b) => b.author === author)
    .map((b) => ({
      id: b.id,
      t: shortTitle(b.title),
      d: b.dateRead,
      r: b.rating,
      cover: b.cover,
      color: b.coverColor,
    }));
  return {
    id: author,
    label: author,
    n,
    x: +x.toFixed(1),
    y: +y.toFixed(1),
    r: Math.max(14, Math.min(42, 10 + n * 3.2)),
    books: authorBooks,
  };
});

// Put Murakami (or top author) at center
const top = nodes.sort((a, b) => b.n - a.n)[0];
if (top) {
  top.x = CX;
  top.y = CY;
  // redistribute others
  const others = nodes.filter((n) => n.id !== top.id);
  others.forEach((n, i) => {
    const angle = (i / others.length) * Math.PI * 2 - Math.PI / 2;
    const ring = n.n >= 3 ? 1 : 2;
    const radius = ring === 1 ? 150 : 225;
    n.x = +(CX + Math.cos(angle) * radius).toFixed(1);
    n.y = +(CY + Math.sin(angle) * radius).toFixed(1);
  });
}

// Edges: authors who share a genre, or whose books were finished within 45 days
type Edge = { a: string; b: string; w: number; reason: string };
const edges: Edge[] = [];
const byAuthor = new Map(nodes.map((n) => [n.id, books.filter((b) => b.author === n.id)]));

for (let i = 0; i < nodes.length; i++) {
  for (let j = i + 1; j < nodes.length; j++) {
    const A = nodes[i];
    const B = nodes[j];
    const aBooks = byAuthor.get(A.id)!;
    const bBooks = byAuthor.get(B.id)!;
    const aGenres = new Set(aBooks.flatMap((b) => b.genres));
    const shared = bBooks.flatMap((b) => b.genres).filter((g) => aGenres.has(g));
    const uniqueShared = [...new Set(shared)];
    let temporal = 0;
    for (const ab of aBooks) {
      for (const bb of bBooks) {
        if (Math.abs(ab.dateRead - bb.dateRead) <= 45 * 86400000) temporal += 1;
      }
    }
    const w = uniqueShared.length * 0.6 + temporal;
    if (w >= 1.2 || temporal >= 2 || uniqueShared.length >= 2) {
      edges.push({
        a: A.id,
        b: B.id,
        w,
        reason:
          uniqueShared.length && temporal
            ? `${uniqueShared.slice(0, 2).join(', ')} · read near each other`
            : uniqueShared.length
              ? uniqueShared.slice(0, 3).join(', ')
              : 'read in the same season',
      });
    }
  }
}

const seriesGroups = (() => {
  const m = new Map<string, typeof books>();
  for (const b of books) {
    if (!b.series) continue;
    const list = m.get(b.series) ?? [];
    list.push(b);
    m.set(b.series, list);
  }
  return [...m.entries()]
    .filter(([, list]) => list.length >= 2)
    .sort((a, b) => b[1].length - a[1].length)
    .map(([name, list]) => ({
      name,
      author: list[0].author,
      books: list
        .slice()
        .sort((a, b) => (a.seriesIndex ?? 99) - (b.seriesIndex ?? 99) || a.dateRead - b.dateRead)
        .map((b) => ({
          id: b.id,
          t: shortTitle(b.title),
          i: b.seriesIndex,
          d: b.dateRead,
          r: b.rating,
          cover: b.cover,
          color: b.coverColor,
        })),
    }));
})();

const payload = {
  nodes: nodes.map((n) => ({ id: n.id, label: n.label, n: n.n, x: n.x, y: n.y, r: n.r, books: n.books })),
  edges,
  series: seriesGroups,
};
---

<Layout title="Author constellation — Brian" description="Authors as a reading constellation">
  <p class="muted small"><a href="/reading">← Reading</a></p>
  <h1>Constellation</h1>
  <StatsNav current="/reading/stats/constellation" />
  <p class="taste-fingerprint">
    Authors you’ve returned to, drawn as a sky. The center is your gravity well.
    Lines connect writers who share genres — or who you finished in the same stretch of weeks.
  </p>

  <section class="stats-section">
    <h2>The sky</h2>
    <p class="muted small">Hover a star. Click to pin an author and see their shelf.</p>
    <div class="constellation-wrap">
      <div class="constellation-readout muted small" id="const-readout">&nbsp;</div>
      <svg id="constellation" viewBox={`0 0 ${W} ${H}`} role="img" aria-label="Author constellation">
        {edges.map((e) => {
          const a = nodes.find((n) => n.id === e.a)!;
          const b = nodes.find((n) => n.id === e.b)!;
          return (
            <line
              class="const-edge"
              x1={a.x}
              y1={a.y}
              x2={b.x}
              y2={b.y}
              data-a={e.a}
              data-b={e.b}
              data-reason={e.reason}
              style={`stroke-opacity:${Math.min(0.16, 0.04 + e.w * 0.03)}`}
            />
          );
        })}
        {nodes.map((n) => (
          <g class="const-node" data-id={n.id} tabindex="0" role="button" aria-label={`${n.label}, ${n.n} books`}>
            <circle class="const-ring" cx={n.x} cy={n.y} r={n.r + 5} />
            <circle class="const-star" cx={n.x} cy={n.y} r={n.r} />
            <text
              class="const-label"
              x={n.x}
              y={n.y + n.r + 15}
              text-anchor="middle"
            >{n.label.split(' ').pop()}</text>
            <text class="const-count" x={n.x} y={n.y + 4} text-anchor="middle">{n.n}</text>
          </g>
        ))}
      </svg>
    </div>
    <div class="heatmap-detail" id="const-detail" hidden></div>
  </section>

  {seriesGroups.length > 0 && (
    <section class="stats-section">
      <h2>Series arcs</h2>
      <p class="muted small">Where you started a series and how far you got. Covers in reading order within each arc.</p>
      <div class="series-arcs" id="series-arcs">
        {seriesGroups.map((s) => (
          <div class="series-arc">
            <div class="series-arc-head">
              <strong>{s.name}</strong>
              <span class="muted small">{s.author} · {s.books.length} read</span>
            </div>
            <div class="series-track">
              {s.books.map((b, i) => (
                <>
                  {i > 0 && <span class="series-connector" aria-hidden="true" />}
                  <a class="series-cover" href={`/reading/books/${b.id}`} title={`${b.t}${b.r != null ? ` · ${b.r}★` : ''}`}>
                    {b.cover ? (
                      <img src={b.cover} alt="" loading="lazy" width="56" height="84" />
                    ) : (
                      <span class="series-cover-fallback" style={b.color ? `background:${b.color}` : ''} />
                    )}
                    {b.i != null && <span class="series-num">#{b.i}</span>}
                  </a>
                </>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <p class="muted small stats-footnote">
    Only authors with two or more books appear as stars. Solo authors still live on the
    <a href="/reading/stats">overview</a>.
  </p>

  <script type="application/json" id="const-data" set:html={safeJsonForScript(payload)} />
</Layout>

<script>
  import { esc, bookHref, bookId, safeCoverSrc, safeHex } from '../../../lib/dom-safe';

  const data = JSON.parse(document.getElementById('const-data').textContent);
  const byId = new Map(data.nodes.map((n) => [n.id, n]));
  const readout = document.getElementById('const-readout');
  const detail = document.getElementById('const-detail');
  let pinned = null;


  function setActive(id) {
    for (const g of document.querySelectorAll('.const-node')) {
      g.classList.toggle('is-active', g.dataset.id === id);
      g.classList.toggle('is-dim', id && g.dataset.id !== id);
      if (g.dataset.id === id) g.setAttribute('aria-pressed', 'true');
      else g.removeAttribute('aria-pressed');
    }
    for (const e of document.querySelectorAll('.const-edge')) {
      const on = !id || e.dataset.a === id || e.dataset.b === id;
      e.classList.toggle('is-dim', !!(id && !on));
      e.classList.toggle('is-lit', !!(id && on));
    }
  }

  function showDetail(id) {
    const n = byId.get(id);
    if (!n) return;
    const fmt = new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' });
    detail.innerHTML =
      `<p class="heatmap-detail-title">${esc(n.label)} — ${n.n} books</p>` +
      '<ul class="const-book-list">' +
      n.books
        .slice()
        .sort((a, b) => b.d - a.d)
        .map(
          (b) =>
            `<li><a href="${bookHref(b.id)}">${esc(b.t)}</a>` +
            `<span class="muted small">${fmt.format(b.d)}${b.r != null ? ` · ${b.r}★` : ''}</span></li>`
        )
        .join('') +
      '</ul>';
    detail.hidden = false;
  }

  document.getElementById('constellation')?.addEventListener('pointerover', (e) => {
    const g = e.target.closest?.('.const-node');
    if (!g) return;
    const n = byId.get(g.dataset.id);
    if (!n) return;
    readout.textContent = `${n.label} — ${n.n} books`;
    if (!pinned) setActive(n.id);
  });

  document.getElementById('constellation')?.addEventListener('pointerout', (e) => {
    if (e.target.closest?.('.const-node') && !pinned) {
      readout.innerHTML = '&nbsp;';
      setActive(null);
    }
  });

  document.getElementById('constellation')?.addEventListener('click', (e) => {
    const g = e.target.closest?.('.const-node');
    if (!g) return;
    const id = g.dataset.id;
    if (pinned === id) {
      pinned = null;
      detail.hidden = true;
      setActive(null);
      readout.innerHTML = '&nbsp;';
      return;
    }
    pinned = id;
    setActive(id);
    showDetail(id);
  });

  // subtle drift — keep rings/labels in sync
  if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const nodes = [...document.querySelectorAll('.const-node')];
    const bases = nodes.map((g) => {
      const star = g.querySelector('.const-star');
      return {
        g,
        star,
        ring: g.querySelector('.const-ring'),
        count: g.querySelector('.const-count'),
        label: g.querySelector('.const-label'),
        cx: +star.getAttribute('cx'),
        cy: +star.getAttribute('cy'),
        r: +star.getAttribute('r'),
        phase: Math.random() * Math.PI * 2,
      };
    });
    let t0 = performance.now();
    const tick = (t) => {
      const sec = (t - t0) / 1000;
      for (const b of bases) {
        const dx = Math.sin(sec * 0.22 + b.phase) * 1.4;
        const dy = Math.cos(sec * 0.18 + b.phase) * 1.1;
        const x = b.cx + dx;
        const y = b.cy + dy;
        b.star.setAttribute('cx', String(x));
        b.star.setAttribute('cy', String(y));
        if (b.ring) {
          b.ring.setAttribute('cx', String(x));
          b.ring.setAttribute('cy', String(y));
        }
        if (b.count) {
          b.count.setAttribute('x', String(x));
          b.count.setAttribute('y', String(y + 4));
        }
        if (b.label) {
          b.label.setAttribute('x', String(x));
          b.label.setAttribute('y', String(y + b.r + 15));
        }
      }
      requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }
</script>
