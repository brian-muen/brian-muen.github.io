---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import {
  luminance,
  sanitizeCoverColor,
  shortTitle,
} from '../lib/bookshelf-stats';

const reviews = (await getCollection('reading')).sort((a, b) => {
  const da = a.data.dateRead?.valueOf() ?? 0;
  const db = b.data.dateRead?.valueOf() ?? 0;
  return db - da;
});

const rendered = await Promise.all(
  reviews.map(async (book) => ({ book, Content: (await render(book)).Content }))
);

const shelf = (await getCollection('bookshelf')).sort(
  (a, b) => b.data.dateRead.valueOf() - a.data.dateRead.valueOf()
);

/** Cloth fallback only when no cover color was extracted. */
const CLOTH = '#c8c2b4';

function spineFace(raw: string | null | undefined): string {
  const c = sanitizeCoverColor(raw);
  if (!c) return CLOTH;
  return c;
}

function spineInk(hex: string): string {
  return luminance(hex) > 0.45 ? 'rgba(20,18,16,0.88)' : 'rgba(255,255,255,0.92)';
}

const spines = shelf.map((b) => {
  const color = spineFace(b.data.coverColor);
  return {
    id: b.id,
    title: shortTitle(b.data.title),
    author: b.data.author,
    color,
    ink: spineInk(color),
    href: `/reading/books/${b.id}`,
  };
});

// Easter egg: a fake spine that opens reading stats
spines.push({
  id: 'how-to-lie',
  title: 'How to Lie',
  author: 'Darrell Huff',
  color: '#3d4a3a',
  ink: spineInk('#3d4a3a'),
  href: '/reading/stats',
});
---

<Layout title="Reading — Brian" description="Books I've read">
  <h1>Reading</h1>

  {spines.length > 0 && (
    <div class="shelf-scroller" id="shelf-scroller" aria-label="Virtual bookshelf">
      <div class="shelf-books">
        {/* Three identical runs so the shelf can loop both ways without a hard left stop. */}
        {[0, 1, 2].map((copy) =>
          spines.map((sp) => (
            <a
              class="spine"
              href={sp.href}
              title={`${sp.title} — ${sp.author}`}
              aria-hidden={copy !== 1 ? 'true' : undefined}
              tabindex={copy !== 1 ? -1 : undefined}
              style={`--spine-face:${sp.color};--spine-ink:${sp.ink}`}
            >
              <span class="spine-title">{sp.title}</span>
            </a>
          ))
        )}
      </div>
    </div>
  )}

  {reviews.length > 0 && (
    <ul class="book-list">
      {rendered.map(({ book, Content }) => (
        <li class="book">
          {book.data.cover ? (
            <img src={book.data.cover} alt={`Cover of ${book.data.title}`} loading="lazy" />
          ) : (
            <div class="book-cover-placeholder">{book.data.title}</div>
          )}
          <div>
            <h2>{book.data.title}</h2>
            <p class="author">{book.data.author}</p>
            <div class="thoughts">
              <Content />
            </div>
          </div>
        </li>
      ))}
    </ul>
  )}
</Layout>

<script>
  // Manual horizontal scroll — three identical spine runs. Start in the middle
  // run so left and right both have a full segment of runway; wrap near the
  // native edges so the shelf never hard-stops (and hover doesn't jitter).
  const scroller = document.getElementById('shelf-scroller');
  if (scroller) {
    let segment = 0;
    let wrapping = false;
    // Stay a few px inside the scrollable range so trackpads never pin at 0 / max.
    const EDGE = 2;

    const measure = () => {
      segment =
        scroller.scrollWidth > scroller.clientWidth ? scroller.scrollWidth / 3 : 0;
    };

    const settleInBand = (x) => {
      if (segment <= 0) return 0;
      let next = x;
      while (next < segment) next += segment;
      while (next >= segment * 2) next -= segment;
      return next;
    };

    const normalize = () => {
      if (segment <= 0 || wrapping) return;
      const x = scroller.scrollLeft;
      const max = scroller.scrollWidth - scroller.clientWidth;
      let next = x;
      // Prefer wrapping inside the middle band; also catch the true right edge
      // when a single run is shorter than the viewport.
      if (x >= Math.min(segment * 2 - EDGE, max - EDGE)) next = x - segment;
      else if (x <= EDGE) next = x + segment;
      else return;
      if (Math.abs(next - x) < 0.5) return;

      wrapping = true;
      scroller.classList.add('is-wrapping');
      scroller.scrollLeft = next;
      // Clear after the browser has applied the jump (and any synthetic scroll).
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          scroller.classList.remove('is-wrapping');
          wrapping = false;
        });
      });
    };

    measure();
    scroller.scrollLeft = segment;
    scroller.addEventListener('scroll', normalize, { passive: true });
    addEventListener('resize', () => {
      const before = segment;
      const ratio = before > 0 ? scroller.scrollLeft / before : 1;
      measure();
      if (segment > 0) scroller.scrollLeft = settleInBand(ratio * segment);
    });
  }
</script>
