---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('writing');
const byDate = (a: typeof allPosts[0], b: typeof allPosts[0]) =>
  b.data.date.valueOf() - a.data.date.valueOf();

const posts = allPosts.filter((p) => !p.id.startsWith('archive/')).sort(byDate);
const archive = allPosts.filter((p) => p.id.startsWith('archive/')).sort(byDate);

const fmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Layout title="Writing — Brian" description="Essays">
  <h1>Writing</h1>
  {posts.length === 0 && archive.length === 0 && <p class="muted">Nothing here yet.</p>}
  {posts.length > 0 && (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/writing/${post.id}`}>{post.data.title}</a>
          <time datetime={post.data.date.toISOString()}>{fmt.format(post.data.date)}</time>
        </li>
      ))}
    </ul>
  )}

  {archive.length > 0 && (
    <details class="archive">
      <summary>Archive</summary>
      <ul class="post-list">
        {archive.map((post) => (
          <li>
            <a href={`/writing/${post.id}`}>{post.data.title}</a>
            <time datetime={post.data.date.toISOString()}>{fmt.format(post.data.date)}</time>
          </li>
        ))}
      </ul>
    </details>
  )}
</Layout>
