---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const path = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/writing', label: 'Writing' },
  { href: '/reading', label: 'Reading' },
];

const social = [
  { href: 'https://x.com/diffferance', label: 'Twitter' },
  { href: 'https://github.com/brian-muen', label: 'GitHub' },
  { href: 'https://app.thestorygraph.com/profile/brian_', label: 'Storygraph' },
];

function isCurrent(href: string) {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href + '/');
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <aside class="sidebar">
      <nav>
        {links.map((l) => (
          <a href={l.href} aria-current={isCurrent(l.href) ? 'page' : undefined}>{l.label}</a>
        ))}
      </nav>
    </aside>
    <div class="content">
      <main>
        <slot />
      </main>
      <footer class="social">
        {social.map((s) => (
          <a href={s.href} rel="me">{s.label}</a>
        ))}
      </footer>
    </div>
  </body>
</html>
